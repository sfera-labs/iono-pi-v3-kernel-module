/dts-v1/;
/plugin/;

/ {
    compatible = "brcm,bcm2835";

    fragment@0 {
        target-path = "/";
        __overlay__ {
            ionopi: ionopi {
                compatible = "sferalabs,ionopi-v3";
                pinctrl-names = "default";
                pinctrl-0 = <&ionopi_pins>;
                status = "okay";

                ionopi_dt1-gpios = <&gpio 4 0>;
                ionopi_dt2-gpios = <&gpio 26 0>;
                ionopi_dt3-gpios = <&gpio 20 0>;
                ionopi_dt4-gpios = <&gpio 21 0>;
                ionopi_di1-gpios = <&gpio 16 0>;
                ionopi_di2-gpios = <&gpio 19 0>;
                ionopi_di3-gpios = <&gpio 13 0>;
                ionopi_di4-gpios = <&gpio 12 0>;
                ionopi_di5-gpios = <&gpio 6 0>;
                ionopi_di6-gpios = <&gpio 5 0>;
                ionopi_led-gpios = <&gpio 23 0>;
                ionopi_do_reset-gpios = <&gpio 17 0>;
                ionopi_do_flag-gpios = <&gpio 18 0>;
                ionopi_do_pdcd-gpios = <&gpio 27 0>;
                ionopi_do_spld-gpios = <&gpio 22 0>;
                ionopi_v5of-gpios = <&gpio 24 0>;
            };
        };
    };

    fragment@1 {
        target = <&gpio>;
        __overlay__ {
            ionopi_pins: ionopi_pins {
                brcm,pins = <16 19 13 12 6 5>;
                brcm,function = <0>; /* in */
                brcm,pull = <0>; /* no pull */
            };
        };
    };

    fragment@2 {
        target = <&spidev0>;
        __overlay__ {
            status = "disabled";
        };
    };

    fragment@3 {
        target = <&spidev1>;
        __overlay__ {
            status = "disabled";
        };
    };

    fragment@4 {
        target = <&spi0>;
        __overlay__ {
            #address-cells = <1>;
            #size-cells = <0>;
            num-chipselects = <2>;
            cs-gpios = <&gpio 8 0 &gpio 7 0>;
            status = "okay";

            mcp3462: mcp3462@0 {
                compatible = "sferalabs,ionopi-v3-mcp3462";
                reg = <0>;
                spi-max-frequency = <20000000>;
            };

            max4896: max4896@1 {
                compatible = "sferalabs,ionopi-v3-max4896";
                reg = <1>;
                spi-max-frequency = <10000000>;
            };
        };
    };

    fragment@5 {
        target = <&i2c_arm>;
        __overlay__ {
            #address-cells = <1>;
            #size-cells = <0>;
            status = "okay";

            pcf2131: pcf2131@53 {
                compatible = "sferalabs,ionopi-v3-pcf2131";
                reg = <0x53>;
                reset-source;
                status = "okay";
            };

            atecc608a: atecc608a@60 {
                compatible = "sferalabs,atecc";
                reg = <0x60>;
                status = "okay";
            };
        };
    };
};
